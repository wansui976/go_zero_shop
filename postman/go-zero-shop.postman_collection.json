            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "try {",
                  "  var json = pm.response.json();",
                  "  var token = json && json.data && json.data.accessToken;",
                  "  if (token) {",
                  "    pm.collectionVariables.set('accessToken', token);",
                  "    pm.environment.set('accessToken', token);",
                  "  }",
                  "} catch (e) {",
                  "  console.log('save token skipped', e);",
                  "}"
                ]
              }
            }
          ]
