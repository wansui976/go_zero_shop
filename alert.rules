# 告警规则 alert.rules
groups:
- name: mysql
  rules:
  - alert: MySQLSlowQueries
    expr: rate(mysql_global_status_slow_queries[5m]) > 10
    for: 2m
    annotations:
      description: "MySQL慢查询过多: {{ $value }}/s"
  
  - alert: MySQLHighQPS
    expr: rate(mysql_global_status_questions[1m]) > 5000
    for: 5m
    annotations:
      description: "MySQL QPS过高: {{ $value }}"