# Reply RPC服务Dockerfile
FROM golang:1.24-alpine AS builder

WORKDIR /app
COPY . .
RUN go mod tidy
RUN CGO_ENABLED=0 GOOS=linux go build -o reply-rpc apps/reply/rpc/reply.go

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
WORKDIR /app
COPY --from=builder /app/reply-rpc .
COPY --from=builder /app/apps/reply/rpc/etc ./etc
EXPOSE 8086
CMD ["./reply-rpc", "-f", "etc/reply.yaml"]