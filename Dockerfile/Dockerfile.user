# 多阶段构建 - 构建阶段
FROM golang:1.21-alpine AS builder

# 设置构建参数
# - CGO_ENABLED=0：禁用 CGO，生成静态链接二进制文件（无需依赖系统库，可在纯 Alpine 镜像中运行）
# - GOOS=linux：指定目标操作系统为 Linux（容器环境）
ARG CGO_ENABLED=0
ARG GOOS=linux

# 安装必要的构建工具
RUN apk add --no-cache git ca-certificates tzdata

# 设置 Go 模块代理（加速国内构建）
ENV GOPROXY=https://goproxy.cn,direct

# 设置工作目录（容器内的项目根目录）
WORKDIR /build

# 复制 go.mod 和 go.sum（利用 Docker 缓存：依赖未变时，无需重新下载）
COPY go.mod go.sum ./
# 下载项目依赖（-mod=mod 确保使用 go.mod 管理依赖）
RUN go mod download

# 复制项目所有源码到容器内
COPY . .

# 构建二进制文件
# - ldflags="-s -w"：去除调试信息，减小二进制文件体积
RUN go build -ldflags="-s -w" -o /app/user-rpc ./apps/user/rpc/user.go




# 运行阶段 - 使用最小化镜像
FROM alpine:3.19

# 安装运行时依赖
RUN apk --no-cache add ca-certificates tzdata

# 设置时区
ENV TZ=Asia/Shanghai

# 创建非 root 用户运行应用
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

# 设置工作目录,运行阶段的根目录
WORKDIR /app

# 从构建阶段复制编译好的二进制文件到运行阶段（仅复制必要文件，减小体积）
COPY --from=builder /app/user-rpc .
# 复制配置文件到运行阶段（运行阶段的配置文件目录）
COPY --from=builder /build/apps/user/rpc/etc/user.yaml ./etc/

# 设置文件权限
RUN chown -R appuser:appgroup /app

# 切换到非 root 用户
USER appuser

# 暴露服务端口
EXPOSE 9000

# 健康检查
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:9000/health || exit 1

# 启动命令
CMD ["./user-rpc", "-f", "./etc/user.yaml"]
